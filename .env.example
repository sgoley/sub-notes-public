# PocketBase admin credentials
PB_ADMIN_EMAIL=admin@localhost.local
PB_ADMIN_PASSWORD=changeme_strong_password
# Note: PB_ENCRYPTION_KEY is auto-generated on first run and stored in the pocketbase_data volume

# API Keys
YOUTUBE_API_KEY=AIza...
GEMINI_API_KEY=AIza...

# Obsidian vault sync (optional)
OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/Obsidian/MyVault
OBSIDIAN_SUBFOLDER=sub-notes

# One-time migration from Supabase (run: bun run migrate)
# SUPABASE_PROJECT_ID=abcdefghijklmnop
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
